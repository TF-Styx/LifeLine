<Page x:Class="LifeLine.AdminPanel.Desktop.Views.Pages.EditDepartmentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LifeLine.AdminPanel.Desktop.Views.Pages" 
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:behaviors="clr-namespace:Shared.WPF.Resources.Behaviors;assembly=Shared.WPF" 
      xmlns:cc="clr-namespace:Shared.WPF.Resources.Controls;assembly=Shared.WPF" 
      xmlns:pages="clr-namespace:LifeLine.AdminPanel.Desktop.ViewModels.Pages" 
      d:DataContext="{d:DesignInstance Type=pages:EditDepartmentPageVM}"
      mc:Ignorable="d"  
      d:Height="500" 
      d:Width="1000"
      Title="EditDepartmentPage">

    <b:Interaction.Behaviors>
        <behaviors:AsyncInitializeBehavior/>
    </b:Interaction.Behaviors>

    <Page.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Arial"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Отдел" 
                       FontSize="30"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="0 0 5 0">
                    <Border Margin="5" Background="{StaticResource App.MainColor}" CornerRadius="6" BorderBrush="#386FD6" BorderThickness="2">
                        <DataGrid ItemsSource="{Binding Departments}" 
                                  SelectedItem="{Binding NewDepartment}"
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  HorizontalContentAlignment="Stretch" 
                                  HeadersVisibility="Column"
                                  Margin="2"
                                  Background="{StaticResource App.MainColor}"
                                  d:ItemsSource="{d:SampleData ItemCount=10}">
                            <DataGrid.Columns>
                                <!-- Наименование -->
                                <DataGridTemplateColumn Header="Наименование" Width="3*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" 
                                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Описание -->
                                <DataGridTemplateColumn Header="Описание" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}" 
                                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Адрес -->
                                <!--<DataGridTemplateColumn Header="Адрес" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding }" 
                                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>-->

                                <!--Информация-->
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Magnifier}"/>
                                                <Button.ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name, StringFormat=Наименование: {0}}"/>
                                                        <TextBlock Text="{Binding Description, StringFormat=Описание: {0}}"/>
                                                    </StackPanel>
                                                </Button.ToolTip>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--Удалить-->
                                <DataGridTemplateColumn Width="35">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="25" Foreground="#F06870" 
                                                    Command="{Binding DataContext.DeleteEducationDocumentCommand, 
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding }" 
                                                    Style="{StaticResource Button.Icon}">
                                                <Control Template="{StaticResource Trash}"/>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Border>

                <ScrollViewer Grid.Column="1" Margin="5 0 0 0" VerticalScrollBarVisibility="Auto">
                    <Border Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="0 0 0 0">
                        <DockPanel Grid.Row="0">
                            <!-- Наименование / Описание -->
                            <StackPanel Margin="5" DockPanel.Dock="Top">
                                <TextBlock Grid.Row="0" Text="Наимевание" 
                                           FontSize="15" Margin="0 0 0 5"
                                           HorizontalAlignment="Center"/>

                                <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Наименование" Margin="0 0 0 5"
                                                       Text="{Binding NewDepartment.Name}" Style="{StaticResource TextBox.PlaceHolder}"/>
                                <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Описание" Margin="0 0 0 0"
                                                       Text="{Binding NewDepartment.Description}" Style="{StaticResource TextBox.PlaceHolder}"/>
                            </StackPanel>

                            <!-- Адрес -->
                            <StackPanel Margin="5" DockPanel.Dock="Top">
                                <TextBlock Grid.Row="0" Text="Адрес" 
                                           FontSize="15" Margin="0 0 0 5"
                                           HorizontalAlignment="Center"/>

                                <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Код" Margin="0 0 0 5" 
                                                       Text="" Style="{StaticResource TextBox.PlaceHolder}"/>
                                <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Регион" Margin="0 0 0 5"
                                                       Text="" Style="{StaticResource TextBox.PlaceHolder}"/>
                                <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Город" Margin="0 0 0 5"
                                                       Text="" Style="{StaticResource TextBox.PlaceHolder}"/>
                                <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Строение/корпус" Margin="0 0 0 5"
                                                       Text="" Style="{StaticResource TextBox.PlaceHolder}"/>
                            </StackPanel>

                            <Button Grid.Row="1" Content="Добавить"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Bottom"
                                    Margin="5"
                                    Command="{Binding OpenPageCommand}"
                                    Style="{StaticResource App.Button}"/>
                        </DockPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Page>
