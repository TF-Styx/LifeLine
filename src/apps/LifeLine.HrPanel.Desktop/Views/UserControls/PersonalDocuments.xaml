<UserControl x:Class="LifeLine.HrPanel.Desktop.Views.UserControls.PersonalDocuments"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LifeLine.HrPanel.Desktop.Views.UserControls" 
             xmlns:cc="clr-namespace:Shared.WPF.Resources.Controls;assembly=Shared.WPF" 
             xmlns:features="clr-namespace:LifeLine.HrPanel.Desktop.ViewModels.Features" 
             d:DataContext="{d:DesignInstance Type=features:PersonalDocumentsVM}"
             xmlns:enum="clr-namespace:LifeLine.HrPanel.Desktop.Enums"
             mc:Ignorable="d" 
             d:Height="auto" 
             d:Width="800">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Arial"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Список документов -->
        <Border Grid.Column="0" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="5">
            <Border Margin="10" Background="{StaticResource App.MainColor}" CornerRadius="6" BorderBrush="#386FD6" BorderThickness="2">
                <DataGrid ItemsSource="{Binding PersonalDocuments.LocalPersonalDocuments}" 
                          SelectedItem="{Binding PersonalDocuments.SelectedLocalPersonalDocument}"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          HorizontalContentAlignment="Stretch" 
                          HeadersVisibility="Column"
                          Margin="2"
                          Background="{StaticResource App.MainColor}"
                          d:ItemsSource="{d:SampleData ItemCount=10}">
                    <DataGrid.Columns>
                        <!--Наименование-->
                        <DataGridTemplateColumn Header="Наименование" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DocumentType.Name}" 
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Файл -->
                        <DataGridTemplateColumn Header="Файл" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FilePath}" 
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--Информация-->
                        <DataGridTemplateColumn Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                        <Control Template="{StaticResource Magnifier}"/>
                                        <Button.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DocumentTypeId, StringFormat=Тип документа: {0}}"/>
                                                <TextBlock Text="{Binding DocumentSeries, StringFormat=Серия: {0}}"/>
                                                <TextBlock Text="{Binding DocumentNumber, StringFormat=Номер: {0}}"/>
                                                <TextBlock Text="{Binding FilePath, StringFormat=Путь: {0}}"/>
                                            </StackPanel>
                                        </Button.ToolTip>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--Удалить-->
                        <DataGridTemplateColumn Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="25" Foreground="#F06870" 
                                           Command="{Binding DataContext.PersonalDocuments.DeletePersonalDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                           CommandParameter="{Binding }" 
                                           Style="{StaticResource Button.Icon}">
                                        <Control Template="{StaticResource Trash}"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>

        <!-- Документы -->
        <Border Grid.Column="1" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="5">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <ComboBox ItemsSource="{Binding DocumentTypes}" 
                          SelectedItem="{Binding PersonalDocuments.DocumentType}" 
                          DisplayMemberPath="Name" Margin="0 10 0 0"/>

                    <!-- Серия / Номер -->
                    <Grid Margin="0 10 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <cc:PlaceHolderTextBox Grid.Column="0" 
                                                   PlaceHolder="Номер*" 
                                                   Margin="0 0 5 0"
                                                   Text="{Binding PersonalDocuments.Number, UpdateSourceTrigger=PropertyChanged}" 
                                                   Style="{StaticResource TextBox.PlaceHolder}"/>

                            <cc:PlaceHolderTextBox Grid.Column="1" 
                                                   PlaceHolder="Серия" 
                                                   Margin="5 0 0 0"
                                                   Text="{Binding PersonalDocuments.Series, UpdateSourceTrigger=PropertyChanged}" 
                                                   Style="{StaticResource TextBox.PlaceHolder}"/>
                        </Grid>

                        <!-- Файл -->
                        <DockPanel Grid.Row="1" Margin="0 10 0 0">
                            <Button Width="25" Foreground="#F06870" 
                                    Command="{Binding PersonalDocuments.SelectMultipleCommand}" 
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource Button.Icon}">
                                <Control Template="{StaticResource AddIcon}"/>
                                <Button.ToolTip>
                                    <TextBlock Text="Добавить файл персональных документов"/>
                                </Button.ToolTip>
                            </Button>
                            <ListView ItemsSource="{Binding PersonalDocuments}">
                                
                            </ListView>
                        </DockPanel>
                    </Grid>
                </StackPanel>

                <Button Grid.Row="1" Content="Добавить локально" Height="40"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center" 
                        Command="{Binding PersonalDocuments.AddPersonalDocumentCommand}"
                        Style="{StaticResource App.Button}" Margin="0 10 0 0"/>

                <Button Grid.Row="2" Content="Продолжить" Height="40"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center" 
                        Command="{Binding ExecuteStepCommand}" CommandParameter="{x:Static enum:EmployeeCreationSteps.EducationDocuments}"
                        Style="{StaticResource App.Button}" Margin="0 10 0 0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
