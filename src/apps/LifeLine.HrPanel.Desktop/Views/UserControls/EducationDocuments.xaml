<UserControl x:Class="LifeLine.HrPanel.Desktop.Views.UserControls.EducationDocuments"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LifeLine.HrPanel.Desktop.Views.UserControls" 
             xmlns:cc="clr-namespace:Shared.WPF.Resources.Controls;assembly=Shared.WPF" 
             xmlns:features="clr-namespace:LifeLine.HrPanel.Desktop.ViewModels.Features" 
             d:DataContext="{d:DesignInstance Type=features:EducationDocumentsVM}"
             xmlns:enum="clr-namespace:LifeLine.HrPanel.Desktop.Enums"
             mc:Ignorable="d" 
             d:Height="auto" 
             d:Width="1000">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Arial"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Список документов об образовании -->
        <Border Grid.Column="0" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="0 0 5 0">
            <Border Margin="5" Background="{StaticResource App.MainColor}" CornerRadius="6" BorderBrush="#386FD6" BorderThickness="2">
                <DataGrid ItemsSource="{Binding EducationDocuments.LocalEducationDocuments}" 
                                          SelectedItem="{Binding EducationDocuments.SelectedEducationDocumentDisplay}"
                                          AutoGenerateColumns="False" 
                                          CanUserAddRows="False"
                                          HorizontalContentAlignment="Stretch" 
                                          HeadersVisibility="Column"
                                          Margin="2"
                                          Background="{StaticResource App.MainColor}"
                                          d:ItemsSource="{d:SampleData ItemCount=10}">
                    <DataGrid.Columns>
                        <!-- Тип документа -->
                        <DataGridTemplateColumn Header="Тип документа" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DocumentType.Name}" 
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Уровень образования -->
                        <DataGridTemplateColumn Header="Уровень образования" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding EducationLevel.Name}" 
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- Файл -->
                        <DataGridTemplateColumn Header="Файл" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FilePath}" 
                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--Информация-->
                        <DataGridTemplateColumn Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                        <Control Template="{StaticResource Magnifier}"/>
                                        <Button.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding EducationLevel.Name, StringFormat=Уровень образования: {0}}"/>
                                                <TextBlock Text="{Binding DocumentType.Name, StringFormat=Тип документа: {0}}"/>
                                                <TextBlock Text="{Binding DocumentNumber, StringFormat=Норме: {0}}"/>
                                                <TextBlock Text="{Binding IssuedDate, StringFormat=Дата выдачи: {0}}"/>
                                                <TextBlock Text="{Binding OrganizationName, StringFormat=Наименование организации: {0}}"/>
                                                <TextBlock Text="{Binding QualificationAwardedName, StringFormat=Наименование присвоеной квалификации: {0}}"/>
                                                <TextBlock Text="{Binding SpecialtyName, StringFormat=Наименование специальности: {0}}"/>
                                                <TextBlock Text="{Binding ProgramName, StringFormat=Наименование программы: {0}}"/>
                                                <TextBlock Text="{Binding TotalHours, StringFormat=Кол-во часов: {0}}"/>
                                                <TextBlock Text="{Binding FilePath, StringFormat=Файл: {0}}"/>
                                            </StackPanel>
                                        </Button.ToolTip>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--Удалить-->
                        <DataGridTemplateColumn Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="25" Foreground="#F06870" 
                                            Command="{Binding DataContext.EducationDocuments.DeleteEducationDocumentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding }" 
                                            Style="{StaticResource Button.Icon}">
                                        <Control Template="{StaticResource Trash}"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            
            <ScrollViewer Grid.Row="0" Margin="5 0 0 0" VerticalScrollBarVisibility="Auto">
                <Border Background="{StaticResource App.SecondColor}" CornerRadius="6">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="50"/>
                        </Grid.RowDefinitions>
                        <!--<CheckBox Content="Использовать документы об образовании" 
                              IsChecked="{Binding IsUseEducationDocument}" 
                              HorizontalAlignment="Center" DockPanel.Dock="Right" Margin="0 0 0 10" 
                              Style="{StaticResource BaseChechBox}"/>-->

                        <!-- Уровень образования / Тип документа -->
                        <StackPanel Grid.Row="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" 
                                          ItemsSource="{Binding DocumentTypes}" 
                                          SelectedItem="{Binding EducationDocuments.DocumentType}"
                                          DisplayMemberPath="Name" 
                                          Margin="0 0 5 0"/>

                                <ComboBox Grid.Column="1" 
                                          ItemsSource="{Binding EducationLevels}" 
                                          SelectedItem="{Binding EducationDocuments.EducationLevel}"
                                          DisplayMemberPath="Name" 
                                          Margin="5 0 0 0"/>
                            </Grid>

                            <!-- Номер документа / Дата выдачи -->
                            <Grid Margin="0 10 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Номер документа*" Margin="0 0 5 0"
                                                       Text="{Binding EducationDocuments.DocumentNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>

                                <DatePicker Grid.Column="1" SelectedDate="{Binding EducationDocuments.IssuedDate, UpdateSourceTrigger=PropertyChanged}" Margin="5 0 0 0"/>
                            </Grid>

                            <!-- Наименование организации / Наименование квалификации -->
                            <Grid Margin="0 10 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Наименование организации*" Margin="0 0 5 0"
                                                       Text="{Binding EducationDocuments.OrganizationName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>

                                <cc:PlaceHolderTextBox Grid.Column="1" PlaceHolder="Наименование квалификации" Margin="5 0 0 0"
                                                       Text="{Binding EducationDocuments.QualificationAwardedName}" Style="{StaticResource TextBox.PlaceHolder}"/>
                            </Grid>

                            <!-- Наименование специальности / Наименование программы -->
                            <Grid Margin="0 10 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Наименование специальности" Margin="0 0 5 0"
                                                       Text="{Binding EducationDocuments.SpecialtyName}" Style="{StaticResource TextBox.PlaceHolder}"/>

                                <cc:PlaceHolderTextBox Grid.Column="1" PlaceHolder="Наименование программы" Margin="5 0 0 0"
                                                       Text="{Binding EducationDocuments.ProgramName}" Style="{StaticResource TextBox.PlaceHolder}"/>
                            </Grid>

                            <!-- Количество часов -->
                            <cc:PlaceHolderTextBox Grid.Column="1" PlaceHolder="Количество часов" Margin="0 10 0 0"
                                                   Text="{Binding EducationDocuments.TotalHours}" Style="{StaticResource TextBox.PlaceHolder}"/>

                            <!-- Файл -->
                            <DockPanel Margin="0 10 0 0">
                                <Button Width="25" Foreground="#F06870" 
                                        Command="{Binding EducationDocuments.SelectMultipleCommand}" 
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource Button.Icon}">
                                    <Control Template="{StaticResource AddIcon}"/>
                                    <Button.ToolTip>
                                        <TextBlock Text="Добавить файл документов об образовании"/>
                                    </Button.ToolTip>
                                </Button>
                                <cc:PlaceHolderTextBox PlaceHolder="Файл" 
                                                       Text="{Binding EducationDocuments.FilePath}" 
                                                       Style="{StaticResource TextBox.PlaceHolder}"/>
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </ScrollViewer>

            <Button Grid.Row="1" Content="Добавить локально" Height="40"
                    HorizontalAlignment="Stretch" VerticalAlignment="Center" 
                    Command="{Binding EducationDocuments.AddEducationDocumentCommandAsync}" 
                    Style="{StaticResource App.Button}" Margin="0 10 0 0"/>

            <Button Grid.Row="2" Content="Продолжить" Height="40"
                    HorizontalAlignment="Stretch" VerticalAlignment="Center" 
                    Command="{Binding ExecuteStepCommand}" CommandParameter="{x:Static enum:EmployeeCreationSteps.WorkPermits}"
                    Style="{StaticResource App.Button}" Margin="0 10 0 0"/>
        </Grid>
    </Grid>
</UserControl>
