<UserControl x:Class="LifeLine.HrPanel.Desktop.Views.UserControls.WorkPermits"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LifeLine.HrPanel.Desktop.Views.UserControls" 
             xmlns:cc="clr-namespace:Shared.WPF.Resources.Controls;assembly=Shared.WPF" 
             xmlns:features="clr-namespace:LifeLine.HrPanel.Desktop.ViewModels.Features" 
             d:DataContext="{d:DesignInstance Type=features:WorkPermitsVM}"
             xmlns:enum="clr-namespace:LifeLine.HrPanel.Desktop.Enums"
             mc:Ignorable="d" 
             d:Height="auto" 
             d:Width="auto">
    
    <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Список сертификатов -->
        <Border Grid.Column="0" Background="{StaticResource App.SecondColor}" CornerRadius="6" Margin="0 0 5 0">
            <Border Margin="5" Background="{StaticResource App.MainColor}" CornerRadius="6" BorderBrush="#386FD6" BorderThickness="2">
                <DataGrid ItemsSource="{Binding WorkPermits.LocalWorkPermits}" 
                          SelectedItem="{Binding SelectedWorkPermit}"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          HorizontalContentAlignment="Stretch" 
                          HeadersVisibility="Column"
                          Margin="2"
                          Background="{StaticResource App.MainColor}"
                          d:ItemsSource="{d:SampleData ItemCount=10}">
                    <DataGrid.Columns>
                        <!-- Тип документа -->
                        <DataGridTemplateColumn Header="Тип документа" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PermitType.Name}" 
                                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Статус -->
                        <DataGridTemplateColumn Header="Статус" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AdmissionStatus.Name}" 
                                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Наименование -->
                        <DataGridTemplateColumn Header="Наименование" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding WorkPermitName}" 
                                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Файл -->
                        <DataGridTemplateColumn Header="Файл" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FilePath}" 
                                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--Информация-->
                        <DataGridTemplateColumn Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="25" Command="{Binding DeleteImageCommand}" Style="{StaticResource Button.Icon}">
                                        <Control Template="{StaticResource Magnifier}"/>
                                        <Button.ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding PermitType.Name, StringFormat=Типа документа: {0}}"/>
                                                <TextBlock Text="{Binding AdmissionStatus.Name, StringFormat=Статус документа: {0}}"/>
                                                <TextBlock Text="{Binding WorkPermitName, StringFormat=Наименование: {0}}"/>
                                                <TextBlock Text="{Binding DocumentSeries, StringFormat=Серия: {0}}"/>
                                                <TextBlock Text="{Binding WorkPermitNumber, StringFormat=Номер разрешения на работу: {0}}"/>
                                                <TextBlock Text="{Binding ProtocolNumber, StringFormat=Номер протокола: {0}}"/>
                                                <TextBlock Text="{Binding SpecialtyName, StringFormat=Наименование специальности: {0}}"/>
                                                <TextBlock Text="{Binding IssuingAuthority, StringFormat=Орган выдающий документы: {0}}"/>
                                                <TextBlock Text="{Binding IssueDate, StringFormat=Дата выдачи: {0}}"/>
                                                <TextBlock Text="{Binding ExpiryDate, StringFormat=Дата истечения срока действия: {0}}"/>
                                                <TextBlock Text="{Binding FilePath, StringFormat=Файл: {0}}"/>
                                            </StackPanel>
                                        </Button.ToolTip>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--Удалить-->
                        <DataGridTemplateColumn Width="35">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="25" Foreground="#F06870" 
                                            Command="{Binding DataContext.WorkPermits.DeleteWorkPermitCommand, 
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding }" 
                                            Style="{StaticResource Button.Icon}">
                                        <Control Template="{StaticResource Trash}"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>

        <ScrollViewer Grid.Column="1" Margin="5 0 0 0" VerticalScrollBarVisibility="Auto">
            <Border Background="{StaticResource App.SecondColor}" CornerRadius="6">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <!-- Тип документа / Статус -->
                        <ComboBox Grid.Column="0" 
                                  ItemsSource="{Binding PermitTypes}" 
                                  SelectedItem="{Binding WorkPermits.PermitType}"
                                  DisplayMemberPath="Name" 
                                  Margin="0 0 0 5"/>

                        <ComboBox Grid.Column="1" 
                                  ItemsSource="{Binding AdmissionStatuses}" 
                                  SelectedItem="{Binding WorkPermits.AdmissionStatus}"
                                  DisplayMemberPath="Name" 
                                  Margin="0 5 0 10"/>

                        <!-- Наименование документа / Наименование специальности -->
                        <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Наименование документа*" Margin="0 0 0 5"
                                               Text="{Binding WorkPermits.WorkPermitName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>

                        <cc:PlaceHolderTextBox Grid.Column="1" PlaceHolder="Наименование специальности*" Margin="0 0 0 5"
                                               Text="{Binding WorkPermits.SpecialtyName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>

                        <!-- Серия / Номер -->
                        <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Серия" Margin="0 0 0 5"
                                               Text="{Binding WorkPermits.DocumentSeries, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>

                        <cc:PlaceHolderTextBox Grid.Column="1" PlaceHolder="Номер*" Margin="0 0 0 5"
                                               Text="{Binding WorkPermits.WorkPermitNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.PlaceHolder}"/>

                        <!-- Номер протокола / Орган выдающий документы -->
                        <cc:PlaceHolderTextBox Grid.Column="0" PlaceHolder="Номер протокола" Margin="0 0 0 5"
                                               Text="{Binding WorkPermits.ProtocolNumber}" Style="{StaticResource TextBox.PlaceHolder}"/>

                        <cc:PlaceHolderTextBox Grid.Column="1" PlaceHolder="Орган выдающий документы*" Margin="0 0 0 10"
                                               Text="{Binding WorkPermits.IssuingAuthority}" Style="{StaticResource TextBox.PlaceHolder}"/>

                        <!-- Дата выдачи / Дата окончания -->
                        <DatePicker Grid.Column="0" SelectedDate="{Binding WorkPermits.IssueDate, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 10"/>

                        <DatePicker Grid.Column="1" SelectedDate="{Binding WorkPermits.ExpiryDate, UpdateSourceTrigger=PropertyChanged}" Margin="0 0 0 10"/>

                        <!-- Файл -->
                        <StackPanel Grid.Row="1" Margin="0 10 0 0">
                            <Button Content="Выбрать скан" 
                                    Width="170" Height="40" 
                                    HorizontalAlignment="Right"
                                    Command="{Binding WorkPermits.SelectMultipleCommand}" 
                                    Style="{StaticResource App.Button}"/>

                            <ListView x:Name="ItemsListView"
                                      ItemsSource="{Binding WorkPermits.PendingFilePaths}"
                                      d:ItemsSource="{d:SampleData ItemCount=3}"
                                      Background="#1E1E1E"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <!-- Горизонтальная виртуализация -->

                                <!-- Панель для горизонтального расположения -->
                                <ListView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" 
                                                    IsItemsHost="True"
                                                    Margin="0"/>
                                        <!-- Отступы вокруг всех items -->
                                    </ItemsPanelTemplate>
                                </ListView.ItemsPanel>

                                <!-- Стиль ListViewItem -->
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Margin" Value="0"/>
                                        <!-- Отступ между items -->
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>

                                        <!-- Убираем стандартное выделение -->
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                                        <Style.Triggers>
                                            <!-- Выделение при наведении -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                                <Setter Property="Background" Value="Magenta"/>
                                                <Setter Property="BorderBrush" Value="Magenta"/>
                                            </Trigger>

                                            <!-- Выделение выбранного элемента -->
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#386FD6"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <!-- Шаблон элемента (ваш Item) -->
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource App.SecondColor}" CornerRadius="6">
                                            <!-- Ширина каждого item -->
                                            <Border BorderBrush="#386FD6" 
                                                    Background="{StaticResource App.MainColor}" 
                                                    BorderThickness="2" 
                                                    CornerRadius="10" 
                                                    HorizontalAlignment="Left" 
                                                    VerticalAlignment="Top" 
                                                    Margin="5">
                                                <StackPanel>
                                                    <Border BorderThickness="0 0 0 2" BorderBrush="#386FD6">
                                                        <StackPanel>
                                                            <!-- 👇 Превью: если есть Thumbnail — показываем, иначе заглушка -->
                                                            <Grid Width="150" Height="150" Margin="5">
                                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" 
                                                                       d:Source="C:\Users\texno\Documents\Lightshot\Screenshot_4.png"
                                                                       Visibility="{Binding Thumbnail, Converter={StaticResource NullToVisibilityConverter}}"/>

                                                                <!-- Заглушка если нет превью -->
                                                                <TextBlock Text="{Binding FileExtension}"
                                                                           FontSize="24"
                                                                           FontWeight="Bold"
                                                                           Foreground="#AAAAAA"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{Binding Thumbnail, Converter={StaticResource NotNullToVisibilityConverter}}"/>
                                                            </Grid>

                                                            <!-- 👇 Индекс и имя файла -->
                                                            <TextBlock Text="{Binding Index, StringFormat='#{0}'}"
                                                                       HorizontalAlignment="Center" 
                                                                       FontSize="18" 
                                                                       Margin="0 0 0 2"
                                                                       Foreground="White"
                                                                       FontWeight="Bold"/>
                                                            <TextBlock Text="{Binding FileName}"
                                                                       HorizontalAlignment="Center" 
                                                                       FontSize="12" 
                                                                       Margin="0 0 0 2"
                                                                       Foreground="#AAAAAA"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxWidth="140"/>
                                                            <TextBlock Text="{Binding FileSizeFormatted}"
                                                                       HorizontalAlignment="Center" 
                                                                       FontSize="10" 
                                                                       Margin="0 0 0 5"
                                                                       Foreground="#666666"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Кнопки управления -->
                                                    <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 2 0 2">
                                                        <Button Width="25" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                Command="{Binding Avatar.SelectCommandAsync}">
                                                            <Control Template="{StaticResource AddIcon}"/>
                                                            <Button.ToolTip>
                                                                <TextBlock Text="Добавить аватарку"/>
                                                            </Button.ToolTip>
                                                        </Button>
                                                        <Button Width="25" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                Margin="15 0 15 0"
                                                                Command="{Binding Avatar.SelectCommandAsync}">
                                                            <Control Template="{StaticResource Magnifier}"/>
                                                        </Button>
                                                        <Button Width="25" 
                                                                Background="Transparent" 
                                                                BorderThickness="0"
                                                                Foreground="#F06870"
                                                                Command="{Binding DataContext.WorkPermits.RemovePendingFileCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                                CommandParameter="{Binding }">
                                                            <Control Template="{StaticResource Trash}"/>
                                                            <Button.ToolTip>
                                                                <TextBlock Text="Удалить"/>
                                                            </Button.ToolTip>
                                                        </Button>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Row="1" Content="Добавить локально" Height="40"
                            HorizontalAlignment="Stretch" VerticalAlignment="Center"
                            Command="{Binding WorkPermits.AddWorkPermitCommandAsync}"
                            Style="{StaticResource App.Button}" Margin="0 10 0 0"/>

                    <Button Grid.Row="2" Content="Продолжить" Height="40"
                            HorizontalAlignment="Stretch" VerticalAlignment="Center"
                            Command="{Binding ExecuteStepCommand}" CommandParameter="{x:Static enum:EmployeeCreationSteps.Specialties}"
                            Style="{StaticResource App.Button}" Margin="0 10 0 0"/>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
